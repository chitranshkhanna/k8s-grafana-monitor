{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_requests_total[1m])) by (route)", "legendFormat": "{{ route }}", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "p50 / p95 / p99 Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "options": { "colorMode": "background" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_errors_total[5m]))", "legendFormat": "errors/s", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "id": 4,
      "options": { "colorMode": "background" },
      "title": "Active Users",
      "type": "stat",
      "targets": [{ "expr": "active_users", "legendFormat": "users", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "id": 5,
      "title": "Running Pods",
      "type": "stat",
      "targets": [{ "expr": "count(kube_pod_status_phase{namespace='default', phase='Running'})", "legendFormat": "pods", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "id": 6,
      "title": "CPU Usage",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='default'}[1m]))", "legendFormat": "cpu", "refId": "A" }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["kubernetes", "nodejs", "prometheus"],
  "title": "Monitor App — K8s Dashboard",
  "version": 1
}